# 🪐 Project Meta
PROJECT_NAME="Project Orbit: Jarvis Protocol"
VERSION="3.0"

# 🗄️ Database & Cache URLs (Docker handles this if running locally)
DATABASE_URL=postgresql+asyncpg://orbit_user:super_secret_password@db:5432/orbit_db
REDIS_URL=redis://cache:6379/0

# 🔐 Security Vault
# Generate a real one using: openssl rand -hex 32
SECRET_KEY=change_this_to_something_massive_and_random
ALGORITHM=HS256

# 🧠 Orbit-Speak (Gemini API)
# Get this from Google AI Studio
GEMINI_API_KEY=AIzaSyCoLilVwXpC9F6rYINDg2WIFihIeWIqnMA

# 📈 Forex Guardian (MetaTrader 5 Credentials)
